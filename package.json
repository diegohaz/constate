{
  "name": "constate-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Constate monorepo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diegohaz/constate.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "dev": "pnpm --filter examples dev",
    "test": "vitest",
    "tsc": "tsc -b",
    "lint": "oxlint --type-aware --type-check . && oxfmt --check .",
    "lint-fix": "oxlint --type-aware --type-check --fix . && oxfmt .",
    "format": "oxfmt .",
    "format-check": "oxfmt --check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/apply-release-plan": "7.1.1",
    "@changesets/cli": "2.31.1",
    "@changesets/config": "3.1.4",
    "@changesets/types": "6.1.0",
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "pkg-pr-new": "0.0.78",
    "rolldown": "1.2.0",
    "rolldown-plugin-dts": "0.27.11",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{js,ts,jsx,tsx}": [
      "oxlint --type-aware --type-check"
    ]
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.13.1"
}
